# Copy to .env.local and fill in the bits you want.
# Defaults assume local dev: filesystem storage, no auth, mocked LLM responses.

# Real LLM output (optional — without it, generators return realistic mocks)
ANTHROPIC_API_KEY=

# Auth gate (optional — without it, the app is open). Set to any long random string.
APP_AUTH_TOKEN=

# Storage driver (optional — auto-detects: redis if UPSTASH_REDIS_REST_URL is set, fs otherwise)
# STORAGE_DRIVER=fs

# Upstash Redis (set both to use redis storage — works on Vercel + local)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
